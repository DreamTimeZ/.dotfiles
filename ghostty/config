# Window size (matches iTerm2 default profile)
window-width = 122
window-height = 29

# Window position on the primary monitor, in points from the top-left.
# Horizontally centered; vertically between the top edge and the center.
window-position-x = 480
window-position-y = 120

# Font
font-family = "MesloLGS Nerd Font Mono"

# Silence bell
bell-features = no-system,no-audio,no-attention,no-title,no-border

# Clipboard: allow apps to read without prompting
clipboard-read = allow

# Disable paste protection (triggers on Espanso multi-line expansions)
clipboard-paste-protection = false

# No confirmation on close/quit (single lever governs both Cmd+W and Cmd+Q)
confirm-close-surface = false

# Page Up/Down: scroll terminal scrollback
keybind = page_up=scroll_page_up
keybind = page_down=scroll_page_down

# Option+Backspace: send ESC+DEL (backward-kill-word)
# Removed as default in Ghostty 1.2+ (PR #7320)
keybind = opt+backspace=text:\x1b\x7f

# Option+Delete: forward delete one word (ESC+d)
keybind = opt+delete=text:\x1bd

# Cmd+Backspace: delete to beginning of line (Ctrl+U)
keybind = super+backspace=text:\x15

# Cmd+Delete: forward delete to end of line (Ctrl+K)
keybind = super+delete=text:\x0b

# Alt+Up/Down: jump to start/end of the zsh input buffer (sends Esc-< / Esc->)
keybind = alt+up=text:\x1b<
keybind = alt+down=text:\x1b>

# Equalize splits: the default super+ctrl+= is untypable on QWERTZ ("=" is shift+0)
keybind = super+ctrl+e=equalize_splits
